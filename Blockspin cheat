-- PATHFINDING
local pathOn=false
local function pathTo(target, timeout)
    local hrp=getHRP(); local hum=getHum()
    if not hrp or not hum then return false end
    local path=PathSvc:CreatePath({AgentRadius=2,AgentHeight=5,AgentCanJump=true,WaypointSpacing=4})
    local ok=pcall(function() path:ComputeAsync(hrp.Position,target) end)
    if not ok or path.Status~=Enum.PathStatus.Success then
        hum:MoveTo(target)
        local s=tick(); while tick()-s<(timeout or 20) do
            local h=getHRP(); if h and (h.Position-target).Magnitude<6 then return true end; task.wait(0.15)
        end; return false
    end
    pathOn=true; local wps=path:GetWaypoints(); local s=tick()
    for _,wp in ipairs(wps) do
        if not pathOn or tick()-s>(timeout or 30) then return false end
        if wp.Action==Enum.PathWaypointAction.Jump then pcall(function() hum:ChangeState(Enum.HumanoidStateType.Jumping) end) end
        hum:MoveTo(wp.Position)
        local ws=tick(); while tick()-ws<3 do local h=getHRP(); if not h then return false end; if (h.Position-wp.Position).Magnitude<4 then break end; task.wait(0.1) end
    end
    local h=getHRP(); return h and (h.Position-target).Magnitude<8
end

