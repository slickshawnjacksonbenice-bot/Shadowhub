local TP_SPOTS = {
    ["ATM Alley"]     = Vector3.new(-302, 18, -134),
    ["Gun Dealer"]    = Vector3.new(-450, 18, -220),
    ["Quick-11"]      = Vector3.new(117, 18, -236),
    ["Steakhouse"]    = Vector3.new(-60, 18, -340),
    ["Basketball"]    = Vector3.new(200, 18, -50),
    ["Barber"]        = Vector3.new(-172, 18, -280),
    ["Gas Station"]   = Vector3.new(300, 18, -180),
    ["Garage"]        = Vector3.new(-380, 18, -90),
    ["Spin Club"]     = Vector3.new(-150, 18, -100),
    ["Sewers"]        = Vector3.new(-200, 5, -200),
}
local function teleportTo(name)
    local pos = TP_SPOTS[name]
    if not pos then warn("[BS] Unknown location: "..name); return end
    local hrp = getHRP()
    if not hrp then warn("[BS] No character"); return end
    -- Smooth: move in steps to avoid any distance-per-frame checks
    local startPos = hrp.Position
    local dist = (pos - startPos).Magnitude
    if dist < 20 then
        hrp.CFrame = CFrame.new(pos)
        return
    end
    -- Teleport in chunks of 50 studs to be safe
    local steps = math.ceil(dist / 50)
    for i = 1, steps do
        local alpha = i / steps
        local mid = startPos:Lerp(pos, alpha)
        pcall(function() hrp.CFrame = CFrame.new(mid) end)
        task.wait(0.05)
    end
    warn("[BS] Teleported to " .. name)
end

-- QUEST CLAIM (reads actual quest data, only claims COMPLETED + UNCLAIMED)
local function claimAll()
    if not GR then warn("[BS] No Get remote"); return end
    local claimed = 0

    -- Method 1: Read the game's Data module for actual quest states
    local gotData = false
    pcall(function()
        local D = require(RS.Modules.Core.Data)
        if D and D.active_quests then
            gotData = true
            for questKey, questInfo in pairs(D.active_quests) do
                if questInfo.completed and not questInfo.claimed then
                    task.wait(0.2)
                    local ok, result = pcall(function()
                        return GR:InvokeServer("claim_quest", questKey)
                    end)
                    if ok and result then
                        claimed = claimed + 1
                        warn("[BS] ✓ Claimed: " .. questKey)
                    end
                end
            end
        end
    end)

    -- Method 2: If Data module failed, brute-force with correct milestone names
    if not gotData then
        warn("[BS] Data module unavailable, brute-forcing...")
        -- These are the ACTUAL milestone names from the dump (SkillsList children)
        local milestones = {
            "stamina", "janitor", "cook", "shelf_stocker",
            "atm_hacker", "total_level", "farmer", "fishing",
            "pistol", "rifle", "shotgun"
        }
        for _, m in ipairs(milestones) do
            for i = 1, 15 do
                local key = m .. "_" .. i
                task.wait(0.15)
                pcall(function() GR:InvokeServer("claim_quest", key) end)
            end
        end
    end

    if claimed > 0 then
        warn("[BS] ✓ Claimed " .. claimed .. " quests!")
    else
        warn("[BS] No claimable quests found (must complete them first)")
    end
end

