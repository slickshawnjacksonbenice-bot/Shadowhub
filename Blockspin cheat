-- ANTI-RAGDOLL (from dump: MS_Ragdoll.lua)
-- Blocks ragdoll by: 1) disabling ragdoll humanoid state, 2) watching
-- for HasBeenDowned/Stunned attributes and immediately firing end_ragdoll_early,
-- 3) blocking Physics state changes
local function setAntiRagdoll(on)
    en.antirag=on; kill("antirag"); kill("antirag2"); kill("antirag3")
    if on then
        -- Block ragdoll state on humanoid
        pcall(function()
            local h=getHum()
            if h then
                h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
                h:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
                h:SetStateEnabled(Enum.HumanoidStateType.Physics,false)
            end
        end)
        -- Heartbeat: if we ever enter ragdoll, immediately fire end_ragdoll_early
        conn("antirag",RunService.Heartbeat,function()
            pcall(function()
                local h=getHum(); if not h then return end
                -- Block ragdoll states every frame
                h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false)
                h:SetStateEnabled(Enum.HumanoidStateType.FallingDown,false)
                h:SetStateEnabled(Enum.HumanoidStateType.Physics,false)
                -- If somehow ragdolled, force back to running
                local st=h:GetState()
                if st==Enum.HumanoidStateType.Ragdoll
                or st==Enum.HumanoidStateType.FallingDown
                or st==Enum.HumanoidStateType.Physics then
                    -- Fire the remote the game uses to cancel ragdoll
                    nS("end_ragdoll_early")
                    h:ChangeState(Enum.HumanoidStateType.GettingUp)
                    task.wait(0.1)
                    h:ChangeState(Enum.HumanoidStateType.Running)
                end
                -- Clear stun/downed attributes
                if h:GetAttribute("Stunned") then
                    nS("end_ragdoll_early")
                end
            end)
        end)
        -- Watch for HasBeenDowned attribute
        pcall(function()
            local h=getHum()
            if h then
                conn("antirag2",h:GetAttributeChangedSignal("HasBeenDowned"),function()
                    if h:GetAttribute("HasBeenDowned") then
                        task.wait(0.05)
                        nS("end_ragdoll_early")
                        h:ChangeState(Enum.HumanoidStateType.GettingUp)
                    end
                end)
                conn("antirag3",h:GetAttributeChangedSignal("Stunned"),function()
                    if h:GetAttribute("Stunned") then
                        task.wait(0.05)
                        nS("end_ragdoll_early")
                        h:ChangeState(Enum.HumanoidStateType.GettingUp)
                    end
                end)
            end
        end)
    else
        pcall(function()
            local h=getHum()
            if h then
                h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,true)
                h:SetStateEnabled(Enum.HumanoidStateType.FallingDown,true)
                h:SetStateEnabled(Enum.HumanoidStateType.Physics,true)
            end
        end)
    end
end

-- STAMINA (SAFE VALUES from dump: Sprint.lua)
-- Drain formula: 10 * StaminaConsumeMultiplier * dt / MaxStamina per frame
-- 0.05 was too low = server saw you sprinting forever = flagged as teleporting
-- 0.3 drain + 8 regen = you barely drain and refill extremely fast = no flag
local function setStamina(on)
    en.stamina=on; kill("stamina")
    if on then
        -- Safe values: drain slow enough to feel infinite, regen fast enough to refill in ~1s
        -- But NOT so extreme that the server flags the bar replication as impossible
        pcall(function() lp:SetAttribute("StaminaConsumeMultiplier",0.3) end)
        pcall(function() lp:SetAttribute("StaminaRegen",8) end)
        local t=0
        conn("stamina",RunService.Heartbeat,function(dt)
            t=t+dt
            if t>=2 then
                t=0
                pcall(function() lp:SetAttribute("StaminaConsumeMultiplier",0.3) end)
                pcall(function() lp:SetAttribute("StaminaRegen",8) end)
            end
            -- Also force the bar to never hit zero (the game stops sprint at 0)
            pcall(function()
                local sprintMod = nil
                pcall(function() sprintMod = require(RS.Modules.Game.Sprint) end)
                if sprintMod and sprintMod.sprint_bar then
                    local bar = sprintMod.sprint_bar.get()
                    if bar and bar < 0.3 then
                        sprintMod.sprint_bar.set(0.8)
                    end
                end
            end)
        end)
    else
        pcall(function() lp:SetAttribute("StaminaConsumeMultiplier",1) end)
        pcall(function() lp:SetAttribute("StaminaRegen",2) end)
    end
end

